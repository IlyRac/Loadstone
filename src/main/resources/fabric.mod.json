{
	"schemaVersion": 1,
	"id": "loadstone",
	"version": "1.0",
	"name": "Load Stone",
	"description": "Keep chunks loaded with upgradable Lodestone chunk loaders.",
	"authors": [
		"IlyRash"
	],
    "custom": {
