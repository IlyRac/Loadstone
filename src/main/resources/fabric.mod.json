{
	"schemaVersion": 1,
	"id": "loadstone",
	"version": "${version}",
	"name": "Loadstone",
	"description": "Turn vanilla Lodestones into reliable, persistent, tiered chunk loaders.",
	"authors": [
		"IlyRac"
	],
	"custom": {
		"modmenu": {
			"links": {
				"Enjoying the mod? Support me!": "https://ko-fi.com/ilyrac",
				"License": "https://github.com/IlyRac/Loadstone/blob/main/LICENSE.md"
			}
		}
	},
	"license": "IlyRac License",
	"icon": "assets/loadstone/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ilyrac.loadstone.Loadstone"
		],
		"client": [
			"com.ilyrac.loadstone.LoadstoneClient"
		]
	},
	"mixins": [
		"loadstone.mixins.json",
		{
			"config": "loadstone.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}